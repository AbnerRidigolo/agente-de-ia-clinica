# Chave da API do OpenRouter (https://openrouter.ai/keys)
# Sem a chave, o servidor sobe em MODO DEMO com um agente simulado.
OPENROUTER_API_KEY=

# Modelo do agente no OpenRouter (padrão: openai/gpt-oss-120b:free)
# Veja modelos em https://openrouter.ai/models
AGENT_MODEL=openai/gpt-oss-120b:free

# Limite de tokens de saída por resposta (padrão: 512)
AGENT_MAX_TOKENS=512

# Metadados opcionais exigidos pelo OpenRouter para ranking
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Agente Clinica Sofia

# Porta do servidor da API (padrão: 3001)
PORT=3001
